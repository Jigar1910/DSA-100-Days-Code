#include <stdio.h>

int main() {
    int rows, cols;

    printf("Enter rows and columns: ");
    scanf("%d %d", &rows, &cols);

    int matrix[rows][cols];

    // Input
    printf("\nEnter elements:\n");
    for(int i = 0; i < rows; i++) {
        for(int j = 0; j < cols; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    int firstRowZero = 0, firstColZero = 0;

    // Check first row
    for(int j = 0; j < cols; j++) {
        if(matrix[0][j] == 0)
            firstRowZero = 1;
    }

    // Check first column
    for(int i = 0; i < rows; i++) {
        if(matrix[i][0] == 0)
            firstColZero = 1;
    }

    // Mark rows and columns
    for(int i = 1; i < rows; i++) {
        for(int j = 1; j < cols; j++) {
            if(matrix[i][j] == 0) {
                matrix[i][0] = 0;
                matrix[0][j] = 0;
            }
        }
    }

    // Set zeroes based on markers
    for(int i = 1; i < rows; i++) {
        for(int j = 1; j < cols; j++) {
            if(matrix[i][0] == 0 || matrix[0][j] == 0) {
                matrix[i][j] = 0;
            }
        }
    }

    // Handle first row
    if(firstRowZero) {
        for(int j = 0; j < cols; j++) {
            matrix[0][j] = 0;
        }
    }

    // Handle first column
    if(firstColZero) {
        for(int i = 0; i < rows; i++) {
            matrix[i][0] = 0;
        }
    }

    // Output
    printf("\nModified Matrix:\n");
    for(int i = 0; i < rows; i++) {
        for(int j = 0; j < cols; j++) {
            printf("%d ", matrix[i][j]);
        }
        printf("\n");
    }

    return 0;
}
