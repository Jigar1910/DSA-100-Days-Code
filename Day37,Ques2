#include <stdio.h>

#define MAX 1000

int heap[MAX];
int size = 0;
int k;

// Swap function
void swap(int *a, int *b) {
    int t = *a;
    *a = *b;
    *b = t;
}

// Heapify up
void heapifyUp(int i) {
    while (i > 0 && heap[(i - 1) / 2] > heap[i]) {
        swap(&heap[i], &heap[(i - 1) / 2]);
        i = (i - 1) / 2;
    }
}

// Heapify down
void heapifyDown(int i) {
    int smallest = i;
    int left = 2 * i + 1;
    int right = 2 * i + 2;

    if (left < size && heap[left] < heap[smallest])
        smallest = left;

    if (right < size && heap[right] < heap[smallest])
        smallest = right;

    if (smallest != i) {
        swap(&heap[i], &heap[smallest]);
        heapifyDown(smallest);
    }
}

// Insert into min heap
void insert(int val) {
    heap[size] = val;
    heapifyUp(size);
    size++;

    // Keep only k elements
    if (size > k) {
        heap[0] = heap[size - 1];
        size--;
        heapifyDown(0);
    }
}

// Get kth largest
int getKthLargest() {
    if (size < k)
        return -1;
    return heap[0];
}

// Display heap (for verification)
void display() {
    printf("Heap: ");
    for (int i = 0; i < size; i++)
        printf("%d ", heap[i]);
    printf("\n");
}

// Main function
int main() {
    k = 3;

    int arr[] = {4, 5, 8, 2, 10, 9};
    int n = sizeof(arr) / sizeof(arr[0]);

    for (int i = 0; i < n; i++) {
        insert(arr[i]);
        printf("After inserting %d → Kth Largest: %d\n", arr[i], getKthLargest());
    }

    return 0;
}
