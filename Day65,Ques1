#include <stdio.h>

#define MAX 100

int visited[MAX];

// DFS function to detect cycle
int dfs(int graph[MAX][MAX], int n, int node, int parent) {
    visited[node] = 1;

    for (int i = 0; i < n; i++) {
        if (graph[node][i] == 1) {

            // If not visited → recurse
            if (!visited[i]) {
                if (dfs(graph, n, i, node))
                    return 1;
            }
            // If visited and not parent → cycle
            else if (i != parent) {
                return 1;
            }
        }
    }
    return 0;
}

// Main function
int hasCycle(int graph[MAX][MAX], int n) {
    for (int i = 0; i < n; i++)
        visited[i] = 0;

    // For disconnected graph
    for (int i = 0; i < n; i++) {
        if (!visited[i]) {
            if (dfs(graph, n, i, -1))
                return 1;
        }
    }
    return 0;
}

int main() {
    int n = 4;

    int graph[MAX][MAX] = {
        {0,1,1,0},
        {1,0,1,0},
        {1,1,0,1},
        {0,0,1,0}
    };

    if (hasCycle(graph, n))
        printf("Cycle exists\n");
    else
        printf("No cycle\n");

    return 0;
}
