#include <stdio.h>

#define MAX 100

int visited[MAX];
int stack[MAX];
int top = -1;

// Push to stack
void push(int v) {
    stack[++top] = v;
}

// DFS function
void dfs(int adj[MAX][MAX], int size[], int node) {
    visited[node] = 1;

    for (int i = 0; i < size[node]; i++) {
        int neighbor = adj[node][i];

        if (!visited[neighbor]) {
            dfs(adj, size, neighbor);
        }
    }

    push(node); // push after visiting all neighbors
}

// Topological Sort
void topoSort(int V, int edges[][2], int E) {
    int adj[MAX][MAX];
    int size[MAX] = {0};

    // Build adjacency list
    for (int i = 0; i < E; i++) {
        int u = edges[i][0];
        int v = edges[i][1];

        adj[u][size[u]++] = v; // directed edge u → v
    }

    // Initialize visited
    for (int i = 0; i < V; i++) {
        visited[i] = 0;
    }

    // Call DFS for all nodes
    for (int i = 0; i < V; i++) {
        if (!visited[i]) {
            dfs(adj, size, i);
        }
    }

    // Print stack (topological order)
    printf("Topological Order: ");
    while (top != -1) {
        printf("%d ", stack[top--]);
    }
}

int main() {
    int V = 6;
    int edges[][2] = {
        {5,2},
        {5,0},
        {4,0},
        {4,1},
        {2,3},
        {3,1}
    };
    int E = 6;

    topoSort(V, edges, E);

    return 0;
}
