#include <stdio.h>
#include <stdlib.h>

// Counting Sort function
void countingSort(int arr[], int n) {
    int i;

    // 1) Find maximum value
    int max = arr[0];
    for (i = 1; i < n; i++) {
        if (arr[i] > max)
            max = arr[i];
    }

    // 2) Create frequency array
    int *count = (int*)calloc(max + 1, sizeof(int));

    // Count occurrences
    for (i = 0; i < n; i++) {
        count[arr[i]]++;
    }

    // 3) Compute prefix sums
    for (i = 1; i <= max; i++) {
        count[i] += count[i - 1];
    }

    // 4) Build output array (stable)
    int *output = (int*)malloc(n * sizeof(int));

    for (i = n - 1; i >= 0; i--) {
        output[count[arr[i]] - 1] = arr[i];
        count[arr[i]]--;
    }

    // 5) Copy back to original array
    for (i = 0; i < n; i++) {
        arr[i] = output[i];
    }

    // Free memory
    free(count);
    free(output);
}

// Print array
void printArray(int arr[], int n) {
    for (int i = 0; i < n; i++)
        printf("%d ", arr[i]);
    printf("\n");
}

int main() {
    int arr[] = {4, 2, 2, 8, 3, 3, 1};
    int n = sizeof(arr) / sizeof(arr[0]);

    countingSort(arr, n);

    printf("Sorted array:\n");
    printArray(arr, n);

    return 0;
}
