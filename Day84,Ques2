#include <stdio.h>

int findPeak(int nums[], int n) {
    int left = 0, right = n - 1;

    while (left < right) {
        int mid = (left + right) / 2;

        if (nums[mid] < nums[mid + 1])
            left = mid + 1;   // peak on right
        else
            right = mid;      // peak on left (including mid)
    }

    return left; // or right (both same)
}

int main() {
    int nums[] = {1, 2, 3, 1};
    int n = sizeof(nums)/sizeof(nums[0]);

    int index = findPeak(nums, n);
    printf("Peak element index: %d\n", index);

    return 0;
}
