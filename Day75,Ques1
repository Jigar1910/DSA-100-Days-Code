#include <stdio.h>

#define MAX 1000

// Simple hash structure
struct Hash {
    int sum;
    int index;
};

int longestZeroSum(int arr[], int n) {
    struct Hash hash[MAX];
    int size = 0;

    int sum = 0, maxLen = 0;

    for(int i = 0; i < n; i++) {
        sum += arr[i];

        if(sum == 0) {
            maxLen = i + 1;
        }

        int found = 0;

        // Search in hash
        for(int j = 0; j < size; j++) {
            if(hash[j].sum == sum) {
                int len = i - hash[j].index;
                if(len > maxLen)
                    maxLen = len;
                found = 1;
                break;
            }
        }

        if(!found) {
            hash[size].sum = sum;
            hash[size].index = i;
            size++;
        }
    }

    return maxLen;
}

int main() {
    int arr[] = {15, -2, 2, -8, 1, 7, 10, 23};
    int n = sizeof(arr)/sizeof(arr[0]);

    int result = longestZeroSum(arr, n);

    printf("Length of longest zero sum subarray: %d\n", result);

    return 0;
}
