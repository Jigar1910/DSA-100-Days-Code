#include <stdio.h>
#include <stdlib.h>

// Node structure
struct Node {
    int data;
    struct Node* next;
};

// Reverse function
struct Node* reverseList(struct Node* head) {
    struct Node* prev = NULL;
    struct Node* curr = head;
    struct Node* next = NULL;

    while (curr != NULL) {
        next = curr->next;   // Step 1
        curr->next = prev;   // Step 2 (reverse link)
        prev = curr;         // Step 3
        curr = next;         // Step 4
    }

    return prev; // new head
}
