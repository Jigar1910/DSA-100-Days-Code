//Given an array of integers nums and an integer target, return indices of the two numbers such that they add up to target.
#include <stdio.h>

int main() {
    int nums[10]={10,23,89,100,45,78,89};
    int n=7;
    int target=189;
    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
            if (nums[i]+nums[j]==target){
                printf("%d%d",i,j);
                return 0;
            }
        }
    }

    return 0;
