#include <stdio.h>

// Function to calculate total hours for given speed k
int canFinish(int piles[], int n, int k, int h) {
    long long hours = 0;

    for (int i = 0; i < n; i++) {
        // ceil(piles[i] / k)
        hours += (piles[i] + k - 1) / k;
    }

    return hours <= h;
}

int minEatingSpeed(int piles[], int n, int h) {
    int left = 1;
    int right = piles[0];

    // find max pile
    for (int i = 1; i < n; i++) {
        if (piles[i] > right)
            right = piles[i];
    }

    int ans = right;

    while (left <= right) {
        int mid = (left + right) / 2;

        if (canFinish(piles, n, mid, h)) {
            ans = mid;
            right = mid - 1;   // try smaller k
        } else {
            left = mid + 1;    // increase k
        }
    }

    return ans;
}

int main() {
    int piles[] = {3, 6, 7, 11};
    int n = 4;
    int h = 8;

    printf("Minimum eating speed: %d\n", minEatingSpeed(piles, n, h));

    return 0;
}
