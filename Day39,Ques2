#include <stdio.h>

#define MAX 1000

// Structure for (value, frequency)
typedef struct {
    int val;
    int freq;
} Node;

Node heap[MAX];
int size = 0;
int k;

// Swap
void swap(Node *a, Node *b) {
    Node t = *a;
    *a = *b;
    *b = t;
}

// Heapify Up (min heap based on freq)
void heapifyUp(int i) {
    while (i > 0 && heap[(i - 1) / 2].freq > heap[i].freq) {
        swap(&heap[i], &heap[(i - 1) / 2]);
        i = (i - 1) / 2;
    }
}

// Heapify Down
void heapifyDown(int i) {
    int smallest = i;
    int left = 2 * i + 1;
    int right = 2 * i + 2;

    if (left < size && heap[left].freq < heap[smallest].freq)
        smallest = left;

    if (right < size && heap[right].freq < heap[smallest].freq)
        smallest = right;

    if (smallest != i) {
        swap(&heap[i], &heap[smallest]);
        heapifyDown(smallest);
    }
}

// Insert into heap
void insert(Node x) {
    heap[size] = x;
    heapifyUp(size);
    size++;

    // Keep only k elements
    if (size > k) {
        heap[0] = heap[size - 1];
        size--;
        heapifyDown(0);
    }
}

// Find top k frequent
void topKFrequent(int nums[], int n, int k_val) {
    k = k_val;

    // Frequency count (simple array hash)
    int freq[10001] = {0};

    for (int i = 0; i < n; i++)
        freq[nums[i]]++;

    // Insert into heap
    for (int i = 0; i < 10001; i++) {
        if (freq[i] > 0) {
            Node temp = {i, freq[i]};
            insert(temp);
        }
    }

    // Print result
    printf("Top %d frequent elements: ", k);
    for (int i = 0; i < size; i++)
        printf("%d ", heap[i].val);
    printf("\n");
}

// Main
int main() {
    int nums[] = {1,1,1,2,2,3};
    int n = sizeof(nums) / sizeof(nums[0]);
    int k = 2;

    topKFrequent(nums, n, k);

    return 0;
}
