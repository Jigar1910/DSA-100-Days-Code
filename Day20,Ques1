//Given an array of integers, count the number of subarrays whose sum is equal to zero.
#include <stdio.h>
#include <stdlib.h>

// Simple hash map using array (for small range)
// For general case, use unordered_map in C++

int countZeroSumSubarrays(int arr[], int n) {
    int sum = 0, count = 0;

    // Using large array as hash (adjust size if needed)
    int hash[20001] = {0}; 
    int offset = 10000; // to handle negative sums

    hash[offset] = 1; // sum = 0 initially

    for (int i = 0; i < n; i++) {
        sum += arr[i];

        if (hash[sum + offset] > 0) {
            count += hash[sum + offset];
        }

        hash[sum + offset]++;
    }

    return count;
}

int main() {
    int arr[] = {1, -1, 0, 2, -2};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("Count: %d\n", countZeroSumSubarrays(arr, n));
    return 0;
}
