#include <stdio.h>
#include <stdlib.h>

struct Node {
    int data;
    struct Node* left;
    struct Node* right;
};

// Preorder: Root → Left → Right
void preorder(struct Node* root) {
    if (root == NULL) return;

    printf("%d ", root->data); // Root
    preorder(root->left);      // Left
    preorder(root->right);     // Right
}
