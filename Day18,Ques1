#include <stdio.h>

int main() {
    int n;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter elements:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int maxSum = arr[0];
    int currentSum = arr[0];

    for(int i = 1; i < n; i++) {

        // Either extend the subarray or start new
        if(currentSum + arr[i] > arr[i]) {
            currentSum = currentSum + arr[i];
        } else {
            currentSum = arr[i];
        }

        // Update max
        if(currentSum > maxSum) {
            maxSum = currentSum;
        }
    }

    printf("\nMaximum Subarray Sum = %d", maxSum);

    return 0;
}
