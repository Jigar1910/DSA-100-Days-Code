#include <stdio.h>

#define MAX 100

int n;
int adj[MAX][MAX];
int visited[MAX];
int disc[MAX], low[MAX], parent[MAX];
int ap[MAX]; // articulation points
int time = 0;

void dfs(int u) {
    visited[u] = 1;
    disc[u] = low[u] = ++time;

    int children = 0;

    for(int v = 0; v < n; v++) {
        if(adj[u][v] == 1) {

            if(!visited[v]) {
                children++;
                parent[v] = u;

                dfs(v);

                // Update low value
                if(low[v] < low[u])
                    low[u] = low[v];

                // Condition 1: root
                if(parent[u] == -1 && children > 1)
                    ap[u] = 1;

                // Condition 2: non-root
                if(parent[u] != -1 && low[v] >= disc[u])
                    ap[u] = 1;
            }
            else if(v != parent[u]) {
                if(disc[v] < low[u])
                    low[u] = disc[v];
            }
        }
    }
}

int main() {

    int m;
    printf("Enter number of vertices and edges: ");
    scanf("%d %d", &n, &m);

    // Initialize
    for(int i = 0; i < n; i++) {
        visited[i] = 0;
        parent[i] = -1;
        ap[i] = 0;

        for(int j = 0; j < n; j++)
            adj[i][j] = 0;
    }

    // Input edges
    printf("Enter edges (u v):\n");
    for(int i = 0; i < m; i++) {
        int u, v;
        scanf("%d %d", &u, &v);

        adj[u][v] = 1;
        adj[v][u] = 1;
    }

    // Run DFS for all components
    for(int i = 0; i < n; i++) {
        if(!visited[i])
            dfs(i);
    }

    // Print articulation points
    printf("Articulation Points:\n");
    for(int i = 0; i < n; i++) {
        if(ap[i])
            printf("%d ", i);
    }

    return 0;
}
