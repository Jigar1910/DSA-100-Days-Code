//Given an array of integers, find two elements whose sum is closest to zero.
#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

// Comparison function for qsort
int compare(const void *a, const void *b) {
    return (*(int *)a - *(int *)b);
}

void closestToZero(int arr[], int n) {
    // Step 1: Sort array
    qsort(arr, n, sizeof(int), compare);

    int left = 0, right = n - 1;
    int min_sum = INT_MAX;
    int res_l = 0, res_r = 0;

    while (left < right) {
        int sum = arr[left] + arr[right];

        // Update minimum sum
        if (abs(sum) < abs(min_sum)) {
            min_sum = sum;
            res_l = arr[left];
            res_r = arr[right];
        }

        // Move pointers
        if (sum < 0)
            left++;
        else
            right--;
    }

    printf("Pair closest to zero: %d and %d\n", res_l, res_r);
}
