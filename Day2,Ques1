//Delete an element from desired location from an array.
#include <stdio.h>

int main() {
    int arr[10]={1,2,3,4,5,6,7,8};
    int n=8;
    int pos=4;
    int i;
    for(int i=pos;i<n;i++){
        arr[i]=arr[i+1];
    }
    n--;
    for(int i=0;i<n;i++){
        printf(" %d",arr[i]);
    }

    return 0;
}
