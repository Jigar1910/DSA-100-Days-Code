#include <stdio.h>
#include <stdlib.h>

// comparison for qsort
int compare(const void *a, const void *b) {
    return (*(int*)a - *(int*)b);
}

void relativeSort(int arr1[], int n, int arr2[], int m) {
    int max = 0;

    // find max element
    for (int i = 0; i < n; i++) {
        if (arr1[i] > max)
            max = arr1[i];
    }

    // frequency array
    int count[max + 1];
    for (int i = 0; i <= max; i++)
        count[i] = 0;

    for (int i = 0; i < n; i++)
        count[arr1[i]]++;

    int index = 0;

    // place elements according to arr2
    for (int i = 0; i < m; i++) {
        while (count[arr2[i]] > 0) {
            arr1[index++] = arr2[i];
            count[arr2[i]]--;
        }
    }

    // place remaining elements sorted
    for (int i = 0; i <= max; i++) {
        while (count[i] > 0) {
            arr1[index++] = i;
            count[i]--;
        }
    }
}

// print array
void printArray(int arr[], int n) {
    for (int i = 0; i < n; i++)
        printf("%d ", arr[i]);
    printf("\n");
}

int main() {
    int arr1[] = {2,3,1,3,2,4,6,7,9,2,19};
    int arr2[] = {2,1,4,3,9,6};

    int n = sizeof(arr1)/sizeof(arr1[0]);
    int m = sizeof(arr2)/sizeof(arr2[0]);

    relativeSort(arr1, n, arr2, m);

    printf("Sorted array:\n");
    printArray(arr1, n);

    return 0;
}
