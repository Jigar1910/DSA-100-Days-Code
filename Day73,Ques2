#include <stdio.h>

#define MAX 1000

int parent[MAX];

// Find with path compression
int find(int x) {
    if(parent[x] != x)
        parent[x] = find(parent[x]);
    return parent[x];
}

// Union
void unionSet(int a, int b) {
    int pa = find(a);
    int pb = find(b);
    if(pa != pb)
        parent[pa] = pb;
}

void findRedundantEdge(int edges[][2], int n) {

    // Initialize parent
    for(int i = 1; i <= n; i++)
        parent[i] = i;

    int ans_u = -1, ans_v = -1;

    for(int i = 0; i < n; i++) {
        int u = edges[i][0];
        int v = edges[i][1];

        int pu = find(u);
        int pv = find(v);

        if(pu == pv) {
            // cycle found
            ans_u = u;
            ans_v = v;
        } else {
            unionSet(u, v);
        }
    }

    printf("Redundant Edge: [%d, %d]\n", ans_u, ans_v);
}

int main() {

    int edges[5][2] = {
        {1,2},
        {1,3},
        {2,3},
        {3,4},
        {4,5}
    };

    int n = 5;

    findRedundantEdge(edges, n);

    return 0;
}
