#include <stdio.h>

#define MAX 1000

void dailyTemperatures(int temp[], int n) {
    int stack[MAX], top = -1;
    int ans[MAX];

    // Initialize answer with 0
    for (int i = 0; i < n; i++)
        ans[i] = 0;

    for (int i = 0; i < n; i++) {

        while (top != -1 && temp[i] > temp[stack[top]]) {
            int prev = stack[top--];
            ans[prev] = i - prev;
        }

        stack[++top] = i;
    }

    // Print result
    for (int i = 0; i < n; i++)
        printf("%d ", ans[i]);
    printf("\n");
}

int main() {
    int temp[] = {73, 74, 75, 71, 69, 72, 76, 73};
    int n = sizeof(temp) / sizeof(temp[0]);

    dailyTemperatures(temp, n);

    return 0;
}
