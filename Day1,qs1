//Insert an element in an array at desired position.
#include <stdio.h>

int main() {

    int arr[10]={1,2,3,4,5,6,7};
    int n=7;
    int pos=3;
    int value=10;
    
    
    for(int i=n;i>pos;i--){
        arr[i]=arr[i-1];
    }
    arr[pos]=value;
    n++;
    for(int i=0;i<n;i++){
        printf(" %d",arr[i]);
    }
    return 0;
}
