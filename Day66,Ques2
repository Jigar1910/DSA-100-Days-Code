#include <stdio.h>

#define MAX 1000

int visited[MAX];
int recStack[MAX];

// DFS to detect cycle
int dfs(int adj[MAX][MAX], int size[], int node) {
    visited[node] = 1;
    recStack[node] = 1;

    for (int i = 0; i < size[node]; i++) {
        int neighbor = adj[node][i];

        if (!visited[neighbor]) {
            if (dfs(adj, size, neighbor))
                return 1;
        }
        else if (recStack[neighbor]) {
            return 1; // cycle found
        }
    }

    recStack[node] = 0; // remove from recursion stack
    return 0;
}

int canFinish(int numCourses, int prerequisites[][2], int sizePre) {
    int adj[MAX][MAX];
    int size[MAX] = {0};

    // Build graph (b → a)
    for (int i = 0; i < sizePre; i++) {
        int a = prerequisites[i][0];
        int b = prerequisites[i][1];

        adj[b][size[b]++] = a;
    }

    // Initialize arrays
    for (int i = 0; i < numCourses; i++) {
        visited[i] = 0;
        recStack[i] = 0;
    }

    // Check all components
    for (int i = 0; i < numCourses; i++) {
        if (!visited[i]) {
            if (dfs(adj, size, i))
                return 0; // false
        }
    }

    return 1; // true
}

int main() {
    int numCourses = 2;

    int prerequisites[][2] = {
        {1,0}
    };

    int sizePre = 1;

    if (canFinish(numCourses, prerequisites, sizePre))
        printf("Yes, you can finish all courses\n");
    else
        printf("No, cycle exists\n");

    return 0;
}
