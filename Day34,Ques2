#include <stdio.h>
#include <ctype.h>

#define MAX 1000

int calculate(char* s) {
    int stack[MAX], top = -1;
    int num = 0;
    char op = '+';

    for (int i = 0; s[i] != '\0'; i++) {

        // Build number
        if (isdigit(s[i])) {
            num = num * 10 + (s[i] - '0');
        }

        // If operator OR end of string
        if ((!isdigit(s[i]) && s[i] != ' ') || s[i + 1] == '\0') {

            if (op == '+')
                stack[++top] = num;
            else if (op == '-')
                stack[++top] = -num;
            else if (op == '*')
                stack[top] = stack[top] * num;
            else if (op == '/')
                stack[top] = stack[top] / num;

            op = s[i];
            num = 0;
        }
    }

    // Sum all values in stack
    int result = 0;
    for (int i = 0; i <= top; i++)
        result += stack[i];

    return result;
}
