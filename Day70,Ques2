#include <stdio.h>
#include <limits.h>

#define INF 1000000000

int findCheapestPrice(int n, int flights[][3], int m, int src, int dst, int k) {
    int dist[n];

    // Initialize distances
    for(int i = 0; i < n; i++)
        dist[i] = INF;

    dist[src] = 0;

    // Relax edges k+1 times
    for(int i = 0; i <= k; i++) {
        int temp[n];

        // Copy current distances
        for(int j = 0; j < n; j++)
            temp[j] = dist[j];

        // Relax edges
        for(int j = 0; j < m; j++) {
            int u = flights[j][0];
            int v = flights[j][1];
            int w = flights[j][2];

            if(dist[u] != INF && dist[u] + w < temp[v]) {
                temp[v] = dist[u] + w;
            }
        }

        // Update dist array
        for(int j = 0; j < n; j++)
            dist[j] = temp[j];
    }

    return (dist[dst] == INF) ? -1 : dist[dst];
}

int main() {
    int n = 4;
    int flights[5][3] = {
        {0,1,100},
        {1,2,100},
        {2,3,100},
        {0,2,500},
        {1,3,600}
    };
    int m = 5;

    int src = 0, dst = 3, k = 1;

    int ans = findCheapestPrice(n, flights, m, src, dst, k);

    printf("Cheapest Price: %d\n", ans);

    return 0;
}
