#include <stdio.h>
#include <stdlib.h>

struct Node {
    int data;
    struct Node* next;
};

int removeCycle(struct Node* head) {
    struct Node *slow = head, *fast = head;

    // Step 1: Detect cycle
    while (fast && fast->next) {
        slow = slow->next;
        fast = fast->next->next;

        if (slow == fast) {
            // Step 2: Find cycle start
            slow = head;

            while (slow != fast) {
                slow = slow->next;
                fast = fast->next;
            }

            // Step 3: Find last node of cycle
            struct Node* temp = fast;
            while (temp->next != slow)
                temp = temp->next;

            temp->next = NULL; // break cycle
            return 1; // cycle removed
        }
    }

    return 0; // no cycle
}
