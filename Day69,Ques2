#include <stdio.h>

#define MAX 100
#define INF 1000000

int minDistance(int dist[], int visited[], int n) {
    int min = INF, index = -1;

    for (int i = 1; i <= n; i++) {
        if (!visited[i] && dist[i] < min) {
            min = dist[i];
            index = i;
        }
    }
    return index;
}

int networkDelayTime(int times[][3], int E, int n, int k) {
    int adj[MAX][MAX];

    // Initialize graph
    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {
            adj[i][j] = INF;
        }
    }

    // Build graph
    for (int i = 0; i < E; i++) {
        int u = times[i][0];
        int v = times[i][1];
        int w = times[i][2];
        adj[u][v] = w;
    }

    int dist[MAX], visited[MAX];

    // Initialize
    for (int i = 1; i <= n; i++) {
        dist[i] = INF;
        visited[i] = 0;
    }

    dist[k] = 0;

    // Dijkstra
    for (int i = 1; i <= n; i++) {
        int u = minDistance(dist, visited, n);
        if (u == -1) break;

        visited[u] = 1;

        for (int v = 1; v <= n; v++) {
            if (!visited[v] && adj[u][v] != INF &&
                dist[u] + adj[u][v] < dist[v]) {
                dist[v] = dist[u] + adj[u][v];
            }
        }
    }

    // Find max distance
    int maxTime = 0;
    for (int i = 1; i <= n; i++) {
        if (dist[i] == INF)
            return -1;
        if (dist[i] > maxTime)
            maxTime = dist[i];
    }

    return maxTime;
}

int main() {
    int times[][3] = {
        {2,1,1},
        {2,3,1},
        {3,4,1}
    };

    int n = 4, E = 3, k = 2;

    int result = networkDelayTime(times, E, n, k);

    printf("Minimum Time: %d\n", result);

    return 0;
}
