#include <stdio.h>
#include <stdlib.h>

struct TreeNode {
    int val;
    struct TreeNode* left;
    struct TreeNode* right;
};

// Create node
struct TreeNode* createNode(int val) {
    struct TreeNode* node = (struct TreeNode*)malloc(sizeof(struct TreeNode));
    node->val = val;
    node->left = node->right = NULL;
    return node;
}

// Search index in inorder
int search(int inorder[], int start, int end, int val) {
    for (int i = start; i <= end; i++) {
        if (inorder[i] == val)
            return i;
    }
    return -1;
}

// Build tree helper
struct TreeNode* build(int inorder[], int postorder[],
                       int inStart, int inEnd, int* postIndex) {
    if (inStart > inEnd)
        return NULL;

    // Root from postorder
    int curr = postorder[*postIndex];
    (*postIndex)--;

    struct TreeNode* root = createNode(curr);

    // If leaf node
    if (inStart == inEnd)
        return root;

    // Find root in inorder
    int pos = search(inorder, inStart, inEnd, curr);

    // IMPORTANT: build right first
    root->right = build(inorder, postorder, pos + 1, inEnd, postIndex);
    root->left  = build(inorder, postorder, inStart, pos - 1, postIndex);

    return root;
}

// Main function to call
struct TreeNode* buildTree(int inorder[], int postorder[], int n) {
    int postIndex = n - 1;
    return build(inorder, postorder, 0, n - 1, &postIndex);
}
