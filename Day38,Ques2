#include <stdio.h>

#define MAX 1000

// Deque using array
int deque[MAX];
int front = 0, rear = -1;

// Sliding window max
void maxSlidingWindow(int nums[], int n, int k) {
    int result[MAX], idx = 0;

    front = 0;
    rear = -1;

    for (int i = 0; i < n; i++) {

        // Remove out-of-window indices
        if (front <= rear && deque[front] <= i - k)
            front++;

        // Remove smaller elements from rear
        while (front <= rear && nums[deque[rear]] < nums[i])
            rear--;

        // Add current index
        deque[++rear] = i;

        // Store result
        if (i >= k - 1)
            result[idx++] = nums[deque[front]];
    }

    // Print result
    printf("Sliding Window Maximum: ");
    for (int i = 0; i < idx; i++)
        printf("%d ", result[i]);
    printf("\n");
}

// Main
int main() {
    int nums[] = {1, 3, -1, -3, 5, 3, 6, 7};
    int n = sizeof(nums) / sizeof(nums[0]);
    int k = 3;

    maxSlidingWindow(nums, n, k);

    return 0;
}
