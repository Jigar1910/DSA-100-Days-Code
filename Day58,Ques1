#include <stdio.h>
#include <stdlib.h>

struct TreeNode {
    int val;
    struct TreeNode* left;
    struct TreeNode* right;
};

// Create node
struct TreeNode* createNode(int val) {
    struct TreeNode* node = (struct TreeNode*)malloc(sizeof(struct TreeNode));
    node->val = val;
    node->left = node->right = NULL;
    return node;
}

// Find index in inorder
int search(int inorder[], int start, int end, int val) {
    for (int i = start; i <= end; i++) {
        if (inorder[i] == val)
            return i;
    }
    return -1;
}

// Build tree
struct TreeNode* buildTree(int preorder[], int inorder[],
                           int inStart, int inEnd, int* preIndex) {
    if (inStart > inEnd)
        return NULL;

    // Pick current root from preorder
    int curr = preorder[*preIndex];
    (*preIndex)++;

    struct TreeNode* node = createNode(curr);

    // If leaf node
    if (inStart == inEnd)
        return node;

    // Find position in inorder
    int pos = search(inorder, inStart, inEnd, curr);

    // Build left and right subtree
    node->left = buildTree(preorder, inorder, inStart, pos - 1, preIndex);
    node->right = buildTree(preorder, inorder, pos + 1, inEnd, preIndex);

    return node;
}
