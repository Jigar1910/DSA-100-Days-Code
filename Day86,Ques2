#include <stdio.h>

int mySqrt(int x) {
    if (x == 0 || x == 1)
        return x;

    int left = 0, right = x;
    int ans = 0;

    while (left <= right) {
        int mid = (left + right) / 2;

        // Avoid overflow
        long long sq = (long long)mid * mid;

        if (sq == x)
            return mid;
        else if (sq < x) {
            ans = mid;        // store possible answer
            left = mid + 1;
        } else {
            right = mid - 1;
        }
    }

    return ans;
}

int main() {
    int x;
    printf("Enter number: ");
    scanf("%d", &x);

    printf("Square root (floor): %d\n", mySqrt(x));
    return 0;
}
