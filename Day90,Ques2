#include <stdio.h>

// Check if we can split into <= k subarrays
int canSplit(int nums[], int n, int k, int maxSum) {
    int subarrays = 1;
    int currentSum = 0;

    for (int i = 0; i < n; i++) {
        if (nums[i] > maxSum)
            return 0;

        if (currentSum + nums[i] <= maxSum) {
            currentSum += nums[i];
        } else {
            subarrays++;
            currentSum = nums[i];
        }

        if (subarrays > k)
            return 0;
    }

    return 1;
}

int splitArray(int nums[], int n, int k) {
    int low = nums[0], high = 0;

    // find max and sum
    for (int i = 0; i < n; i++) {
        if (nums[i] > low)
            low = nums[i];
        high += nums[i];
    }

    int ans = high;

    while (low <= high) {
        int mid = (low + high) / 2;

        if (canSplit(nums, n, k, mid)) {
            ans = mid;
            high = mid - 1;   // try smaller
        } else {
            low = mid + 1;    // increase
        }
    }

    return ans;
}

int main() {
    int nums[] = {7, 2, 5, 10, 8};
    int n = 5;
    int k = 2;

    printf("Minimum largest sum: %d\n", splitArray(nums, n, k));

    return 0;
}
