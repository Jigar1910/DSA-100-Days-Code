#include <stdio.h>

#define MAX 100

int n, m;
int adj[MAX][MAX];
int visited[MAX];
int disc[MAX], low[MAX];
int time = 0;

// DFS function
void dfs(int u, int parent) {
    visited[u] = 1;
    disc[u] = low[u] = ++time;

    for(int v = 0; v < n; v++) {
        if(adj[u][v] == 1) {

            if(!visited[v]) {
                dfs(v, u);

                // Update low value
                if(low[v] < low[u])
                    low[u] = low[v];

                // Check bridge condition
                if(low[v] > disc[u]) {
                    printf("Bridge: %d - %d\n", u, v);
                }
            }
            else if(v != parent) {
                if(disc[v] < low[u])
                    low[u] = disc[v];
            }
        }
    }
}

int main() {

    printf("Enter number of nodes and edges: ");
    scanf("%d %d", &n, &m);

    // Initialize adjacency matrix
    for(int i = 0; i < n; i++)
        for(int j = 0; j < n; j++)
            adj[i][j] = 0;

    printf("Enter edges (u v):\n");
    for(int i = 0; i < m; i++) {
        int u, v;
        scanf("%d %d", &u, &v);

        adj[u][v] = 1;
        adj[v][u] = 1;
    }

    // Initialize arrays
    for(int i = 0; i < n; i++) {
        visited[i] = 0;
        disc[i] = low[i] = -1;
    }

    // Run DFS
    for(int i = 0; i < n; i++) {
        if(!visited[i]) {
            dfs(i, -1);
        }
    }

    return 0;
}
