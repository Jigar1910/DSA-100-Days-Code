#include <stdio.h>
#include <stdlib.h>

#define MAX 100

int visited[MAX];

// DFS function
int dfs(int adj[MAX][MAX], int size[], int node, int parent) {
    visited[node] = 1;

    for (int i = 0; i < size[node]; i++) {
        int neighbor = adj[node][i];

        if (!visited[neighbor]) {
            if (dfs(adj, size, neighbor, node))
                return 1;
        }
        else if (neighbor != parent) {
            return 1;  // Cycle found
        }
    }
    return 0;
}

// Function to detect cycle
int hasCycle(int V, int edges[][2], int E) {
    int adj[MAX][MAX];
    int size[MAX] = {0};

    // Build adjacency list
    for (int i = 0; i < E; i++) {
        int u = edges[i][0];
        int v = edges[i][1];

        adj[u][size[u]++] = v;
        adj[v][size[v]++] = u;
    }

    // Initialize visited
    for (int i = 0; i < V; i++)
        visited[i] = 0;

    // Handle multiple components
    for (int i = 0; i < V; i++) {
        if (!visited[i]) {
            if (dfs(adj, size, i, -1))
                return 1;
        }
    }

    return 0;
}

int main() {
    int V = 5;
    int edges[][2] = {
        {0,1},
        {1,2},
        {2,0},  // cycle here
        {3,4}
    };
    int E = 4;

    if (hasCycle(V, edges, E))
        printf("Cycle exists\n");
    else
        printf("No cycle\n");

    return 0;
}
