#include <stdio.h>
#define MAX 100

int stack[MAX];
int top = -1;

// Push
void push(int value) {
    if (top == MAX - 1) {
        printf("Stack Overflow\n");
        return;
    }
    stack[++top] = value;
}

// Pop
void pop() {
    if (top == -1) {
        printf("Stack Underflow\n");
        return;
    }
    printf("Popped: %d\n", stack[top--]);
}

// Display
void display() {
    if (top == -1) {
        printf("Stack is Empty\n");
        return;
    }

    printf("Stack: ");
    for (int i = top; i >= 0; i--)
        printf("%d ", stack[i]);
    printf("\n");
}

// Main
int main() {
    push(10);
    push(20);
    push(30);

    display();

    pop();
    display();

    return 0;
}
