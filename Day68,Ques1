#include <stdio.h>

#define MAX 100

void topoSort(int V, int edges[][2], int E) {
    int adj[MAX][MAX];
    int size[MAX] = {0};
    int indegree[MAX] = {0};

    // Step 1: Build graph
    for (int i = 0; i < E; i++) {
        int u = edges[i][0];
        int v = edges[i][1];

        adj[u][size[u]++] = v;  // u → v
        indegree[v]++;
    }

    // Step 2: Queue
    int queue[MAX], front = 0, rear = 0;

    for (int i = 0; i < V; i++) {
        if (indegree[i] == 0) {
            queue[rear++] = i;
        }
    }

    // Step 3: Process
    int result[MAX];
    int index = 0;

    while (front < rear) {
        int node = queue[front++];
        result[index++] = node;

        for (int i = 0; i < size[node]; i++) {
            int neighbor = adj[node][i];
            indegree[neighbor]--;

            if (indegree[neighbor] == 0) {
                queue[rear++] = neighbor;
            }
        }
    }

    // Step 4: Check cycle
    if (index != V) {
        printf("Cycle exists. Topological sort not possible.\n");
        return;
    }

    // Print result
    printf("Topological Order: ");
    for (int i = 0; i < V; i++) {
        printf("%d ", result[i]);
    }
}

int main() {
    int V = 6;
    int edges[][2] = {
        {5,2},
        {5,0},
        {4,0},
        {4,1},
        {2,3},
        {3,1}
    };
    int E = 6;

    topoSort(V, edges, E);

    return 0;
}
